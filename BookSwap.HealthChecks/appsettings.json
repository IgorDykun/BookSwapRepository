{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http": "Information",
      "Microsoft.Extensions.Http": "Information"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "MongoDb": "mongodb://localhost:27017"
  },

  "Services": {
    "Aggregator": "https://localhost:7186/health"
  },

  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "Aggregator",
        "Uri": "https://localhost:7186/health"
      },
      {
        "Name": "MongoDB",
        "Uri": "https://localhost:5201/health-mongodb"
      },
      {
        "Name": "Redis",
        "Uri": "https://localhost:5201/health-redis"
      },
      {
        "Name": "RedisStreams",
        "Uri": "https://localhost:5201/health-redis-stream"
      }
    ],
    "EvaluationTimeInSeconds": 5,
    "MinimumSecondsBetweenFailureNotifications": 10
  }
}
